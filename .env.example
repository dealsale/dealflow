# Dominio que apunta a tu VPS (Caddy saca el certificado HTTPS solo)
DOMAIN=panel.tudominio.com

# Cámbialos SIEMPRE en producción
JWT_SECRET=pon-aqui-una-frase-larga-y-secreta
